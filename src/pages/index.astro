---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { PROJECTS, FEATURED, ARCHIVE } from '../data/projects';
---

<Layout title="Manbir Singh — Software Engineer">
  <Nav current="home" />

  <main>
    <!-- Hero -->
    <section class="hero-section">
      <div class="hero-glow" aria-hidden="true"></div>
      <div class="container">
        <div class="eyebrow">● Available Q3 2026 · Toronto, ON · open to remote</div>
        <h1 class="hero-heading">
          Performance,<br />
          <span class="serif-i garnet">engineered.</span>
        </h1>
        <p class="lead hero-lead">
          I'm Manbir — a software engineer building high-performance web applications with React, TypeScript, and Tailwind. I turn complex requirements into clean, performant code.
        </p>
        <div class="hero-actions">
          <a href="#work" class="btn btn-primary">View selected work <span>→</span></a>
          <a href="/contact" class="btn btn-secondary">Get in touch <span>→</span></a>
          <span class="hero-email">hi@manbir.dev</span>
        </div>

        <!-- Metrics ribbon -->
        <div class="glass metrics-ribbon">
          {[
            ['6+',   'years shipping'],
            ['24',   'production launches'],
            ['99',   'Lighthouse, avg.'],
            ['0.6s', 'median LCP'],
            ['Q3',   'next opening'],
          ].map(([n, l]) => (
            <div class="metric">
              <div class="metric-num">{n}</div>
              <div class="eyebrow">{l}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Selected work -->
    <section class="section" id="work">
      <div class="container">
        <div class="section-header">
          <div>
            <div class="eyebrow">Selected work · {FEATURED.length} of {PROJECTS.length}</div>
            <h2 class="section-heading">
              Recent, <span class="serif-i garnet">shipped.</span>
            </h2>
          </div>
          <div class="col-meta">YEAR · METRIC · STACK</div>
        </div>

        <!-- Table header -->
        <div class="table-header">
          <div>№</div>
          <div>PROJECT</div>
          <div>ROLE · YEAR</div>
          <div>STACK</div>
          <div></div>
        </div>

        <!-- Featured rows -->
        <div class="glass-subtle work-table">
          {FEATURED.map((p, i) => (
            <a href={`/work/${p.id}`} class="project-row">
              <div class="row-idx">{String(i + 1).padStart(2, '0')}</div>
              <div class="row-title-col">
                <div class="row-title">{p.title}</div>
                <div class="row-tag">{p.tag.toUpperCase()}</div>
              </div>
              <div class="row-role-col">
                <div class="row-role">{p.role}</div>
                <div class="row-meta">{p.year} · {p.metric}</div>
              </div>
              <div class="row-stack">
                {p.stack.slice(0, 4).map(s => (
                  <span class="chip">{s}</span>
                ))}
              </div>
              <div class="row-arrow">↗</div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Archive -->
    <section class="section-sm">
      <div class="container">
        <div class="section-header">
          <div class="eyebrow">Archive · 2021 — 2023</div>
          <a href="#" class="btn btn-ghost btn-xs">Full list <span>→</span></a>
        </div>
        <div class="glass-subtle archive-table">
          {ARCHIVE.map((p, i) => (
            <div class="archive-row" data-last={i === ARCHIVE.length - 1 ? 'true' : 'false'}>
              <div class="row-idx">{String(FEATURED.length + i + 1).padStart(2, '0')}</div>
              <div class="archive-title">
                {p.title}
                <span class="archive-tag">{p.tag.toUpperCase()}</span>
              </div>
              <div class="archive-meta">{p.year} · {p.role}</div>
              <div class="archive-desc">{p.desc.split('.')[0]}.</div>
              <div class="archive-arrow">↗</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Stack & capabilities -->
    <section class="section">
      <div class="container">
        <div class="eyebrow">Stack &amp; capabilities</div>
        <div class="stack-grid">
          {[
            ['Languages', 'TypeScript', 'JavaScript', 'Go', 'Python', 'SQL'],
            ['Frontend',  'React', 'Next.js', 'Astro', 'Tailwind', 'Framer Motion'],
            ['Backend',   'Node', 'tRPC', 'GraphQL', 'Postgres', 'Prisma'],
            ['Tooling',   'Vite', 'Turborepo', 'Biome', 'Vitest', 'Playwright'],
            ['Infra',     'Vercel', 'Cloudflare', 'Fly.io', 'Docker', 'AWS'],
            ['Design',    'Figma', 'Code-as-tool', 'Motion design', 'Design systems', 'Prototyping'],
          ].map(([cat, ...items]) => (
            <div class="glass-subtle stack-tile">
              <div class="eyebrow" style="color: var(--garnet-400)">{cat}</div>
              <div class="chip-row">
                {items.map(t => (
                  <span class="chip">{t.toUpperCase()}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Experience snapshot -->
    <section class="section-sm">
      <div class="container">
        <div class="eyebrow">Experience</div>
        <div class="glass-subtle exp-table">
          {[
            ['2024 — Now',  'Independent',        'Engineering and design for design-led product teams.'],
            ['2022 — 2024', 'Senior Engineer',     'Frontend platform at a Series-B fintech. Owned design system and motion.'],
            ['2020 — 2022', 'Product Engineer',    'Two YC startups (S20, W22). Zero-to-10k users.'],
            ['2019 — 2020', 'Engineering Intern',  'Big-Four consulting. Internal tools, ad-hoc dashboards.'],
          ].map(([yr, role, desc], i, arr) => (
            <div class="exp-row" data-last={i === arr.length - 1 ? 'true' : 'false'}>
              <div class="eyebrow">{yr}</div>
              <div class="exp-role">{role}</div>
              <div class="exp-desc">{desc}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Closing CTA -->
    <section class="section">
      <div class="container">
        <div class="glass cta-block">
          <div class="cta-text">
            <div class="eyebrow">Currently · open to roles &amp; engagements</div>
            <div class="cta-heading">
              Looking for a frontend or product-engineering team that <span class="serif-i garnet">cares about craft.</span>
            </div>
          </div>
          <div class="cta-actions">
            <a href="/contact" class="btn btn-primary">Send a note <span>→</span></a>
            <a href="#" class="btn btn-secondary">Download résumé <span>↓</span></a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  /* Hero */
  .hero-section {
    padding-top: 64px;
    padding-bottom: 48px;
    position: relative;
    overflow: hidden;
  }

  .hero-glow {
    position: absolute;
    inset: -10% -10% auto auto;
    width: 70%;
    height: 80%;
    background: radial-gradient(ellipse at 70% 30%, rgba(161,25,46,.24), transparent 60%);
    pointer-events: none;
  }

  .hero-heading {
    font-size: clamp(56px, 7.5vw, 104px);
    font-weight: 500;
    line-height: 0.96;
    letter-spacing: -0.04em;
    margin-top: 20px;
    text-wrap: balance;
  }

  .garnet { color: var(--garnet-500); }

  .hero-lead {
    max-width: 720px;
    margin-top: 24px;
    color: var(--fg-2);
    font-size: 20px;
    line-height: 1.5;
  }

  .hero-actions {
    display: flex;
    gap: 14px;
    margin-top: 28px;
    align-items: center;
    flex-wrap: wrap;
  }

  .hero-email {
    margin-left: 8px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--fg-3);
  }

  .metrics-ribbon {
    margin-top: 56px;
    padding: 28px 32px;
    border-radius: 18px;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 24px;
    position: relative;
  }

  .metric-num {
    font: 500 40px/1 var(--font-display);
    letter-spacing: -0.035em;
    color: var(--fg-1);
  }

  .metric .eyebrow { margin-top: 10px; }

  /* Sections */
  .section    { padding: 64px 0 48px; }
  .section-sm { padding: 32px 0 48px; }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 24px;
  }

  .section-heading {
    margin-top: 10px;
    font-size: clamp(28px, 3.5vw, 44px);
    font-weight: 500;
    line-height: 1;
    letter-spacing: -0.025em;
    white-space: nowrap;
  }

  .col-meta {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--fg-3);
  }

  /* Work table */
  .table-header {
    display: grid;
    grid-template-columns: 48px 1.4fr 0.9fr 1.4fr 60px;
    gap: 24px;
    padding: 0 24px 12px;
    border-bottom: var(--border-hairline);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    color: var(--fg-3);
  }

  .work-table {
    border-radius: 18px;
    overflow: hidden;
  }

  .project-row {
    display: grid;
    grid-template-columns: 48px 1.4fr 0.9fr 1.4fr 60px;
    gap: 24px;
    align-items: center;
    padding: 22px 24px;
    border-bottom: var(--border-hairline);
    text-decoration: none;
    transition: background var(--dur-2) var(--ease-out);
  }

  .project-row:last-child { border-bottom: none; }

  .project-row:hover { background: color-mix(in oklab, var(--ink-800) 35%, transparent); }
  .project-row:hover .row-arrow { transform: translate(4px, -4px); opacity: 1; }

  .row-idx {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--fg-3);
    letter-spacing: 0.06em;
  }

  .row-title {
    font: 500 26px/1 var(--font-display);
    letter-spacing: -0.02em;
    color: var(--fg-1);
  }

  .row-tag {
    margin-top: 6px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--fg-3);
    letter-spacing: 0.06em;
  }

  .row-role {
    font-size: 14px;
    color: var(--fg-1);
  }

  .row-meta {
    margin-top: 6px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--fg-3);
    letter-spacing: 0.06em;
  }

  .row-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .row-arrow {
    justify-self: end;
    font-size: 22px;
    color: var(--fg-3);
    transition: transform var(--dur-2) var(--ease-out);
  }

  /* Archive */
  .archive-table {
    border-radius: 14px;
    overflow: hidden;
  }

  .archive-row {
    display: grid;
    grid-template-columns: 48px 1.2fr 0.8fr 1.4fr 60px;
    gap: 24px;
    align-items: center;
    padding: 16px 24px;
    border-bottom: var(--border-hairline);
    font-size: 14px;
    color: var(--fg-2);
  }

  .archive-row[data-last="true"] { border-bottom: none; }

  .archive-title {
    color: var(--fg-1);
    font-weight: 500;
    display: flex;
    align-items: baseline;
    gap: 8px;
  }

  .archive-tag {
    color: var(--fg-3);
    font-weight: 400;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
  }

  .archive-meta {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--fg-3);
  }

  .archive-desc { font-size: 13px; }

  .archive-arrow {
    justify-self: end;
    color: var(--fg-3);
    font-size: 18px;
  }

  /* Stack grid */
  .stack-grid {
    margin-top: 24px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .stack-tile {
    border-radius: 14px;
    padding: 20px 22px;
  }

  .chip-row {
    margin-top: 14px;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  /* Experience */
  .exp-table {
    margin-top: 24px;
    border-radius: 18px;
    padding: 8px 24px;
  }

  .exp-row {
    display: grid;
    grid-template-columns: 180px 280px 1fr;
    gap: 32px;
    padding: 20px 0;
    border-bottom: var(--border-hairline);
  }

  .exp-row[data-last="true"] { border-bottom: none; }

  .exp-role {
    font: 500 18px/1.2 var(--font-display);
    letter-spacing: -0.01em;
    color: var(--fg-1);
  }

  .exp-desc {
    font-size: 14px;
    color: var(--fg-2);
  }

  /* CTA block */
  .cta-block {
    border-radius: 24px;
    padding: 56px 48px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
    flex-wrap: wrap;
  }

  .cta-heading {
    margin-top: 16px;
    font: 500 clamp(28px, 3.2vw, 44px)/1.05 var(--font-display);
    letter-spacing: -0.025em;
    max-width: 720px;
    color: var(--fg-1);
  }

  .cta-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    flex-shrink: 0;
  }

  .btn-xs {
    font-size: 12px;
    padding: 14px 4px;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .metrics-ribbon { grid-template-columns: repeat(3, 1fr); }
    .table-header { display: none; }
    .project-row {
      grid-template-columns: 40px 1fr auto;
      grid-template-rows: auto auto;
    }
    .row-role-col, .row-stack { display: none; }
    .stack-grid { grid-template-columns: repeat(2, 1fr); }
    .exp-row { grid-template-columns: 1fr 1fr; }
    .exp-desc { display: none; }
    .archive-row {
      grid-template-columns: 40px 1fr auto;
    }
    .archive-meta, .archive-desc { display: none; }
  }

  @media (max-width: 640px) {
    .stack-grid { grid-template-columns: 1fr; }
    .cta-block { padding: 32px 24px; }
  }
</style>
