---
interface Props {
  current?: 'home' | 'about' | 'contact' | 'work';
}
const { current = 'home' } = Astro.props;

const items = [
  { href: '/',        label: 'Work',    id: 'home' },
  { href: '/about',   label: 'About',   id: 'about' },
  { href: '/contact', label: 'Contact', id: 'contact' },
];
---

<nav>
  <div class="container">
    <a href="/" class="wordmark">
      <span class="logo-mask" aria-hidden="true"></span>
      <span class="wordmark-text">manbir<span class="dot">.</span></span>
    </a>

    <div class="nav-items">
      {items.map(item => (
        <a
          href={item.href}
          class:list={['nav-link', { 'is-active': current === item.id }]}
        >
          {item.label}
        </a>
      ))}
    </div>

    <a href="/contact" class="btn btn-primary btn-sm">
      Let's talk <span>→</span>
    </a>
  </div>
</nav>

<style>
  nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(10, 9, 8, 0.72);
    backdrop-filter: blur(20px) saturate(140%);
    -webkit-backdrop-filter: blur(20px) saturate(140%);
    border-bottom: 1px solid var(--hairline);
  }

  .container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }

  .wordmark {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    opacity: 1 !important;
  }

  .logo-mask {
    display: block;
    width: 22px;
    height: 22px;
    background: var(--fg-1);
    -webkit-mask: url('/assets/projects/ilknox-logo.svg') center / contain no-repeat;
    mask: url('/assets/projects/ilknox-logo.svg') center / contain no-repeat;
    flex-shrink: 0;
  }

  .wordmark-text {
    font: 500 15px/1 var(--font-sans);
    letter-spacing: -0.01em;
    color: var(--fg-1);
  }

  .dot { color: var(--garnet-500); }

  .nav-items {
    display: flex;
    gap: 32px;
    font: 500 13px/1 var(--font-sans);
    letter-spacing: -0.005em;
    white-space: nowrap;
  }

  .nav-link {
    color: var(--fg-2);
    text-decoration: none;
    transition: color var(--dur-2) var(--ease-out);
  }

  .nav-link:hover,
  .nav-link.is-active {
    color: var(--fg-1);
    opacity: 1;
  }

  .btn-sm {
    padding: 10px 16px;
    font-size: 12px;
  }
</style>
